{
  "name": "celest",
  "author": "TheEastKoi",
  "version": "0.2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/TheEastKoi/celest"
  },
  "extensionKind": [
    "ui",
    "workspace"
  ],
  "license": "Apache-2.0",
  "displayName": "Celest — CodeWhale AI Agent",
  "description": "CodeWhale TUI AI agent for VS Code — full API coverage (37/37), streaming chat, 8 panels, agent/task/skill management, multi-model support (DeepSeek/Qwen/GPT/Ollama)",
  "publisher": "TheEastKoi",
  "icon": "assets/icon.png",
  "galleryBanner": {
    "color": "#0d1117",
    "theme": "dark"
  },
  "bugs": {
    "url": "https://github.com/TheEastKoi/celest/issues"
  },
  "homepage": "https://github.com/TheEastKoi/celest#readme",
  "engines": {
    "vscode": "^1.70.0",
    "node": ">=18.18.0"
  },
  "categories": [
    "AI",
    "Chat",
    "Machine Learning"
  ],
  "keywords": [
    "deepseek",
    "codewhale",
    "ai",
    "agent",
    "coding",
    "celest",
    "qwen",
    "openai",
    "ollama",
    "llm",
    "chat",
    "copilot"
  ],
  "activationEvents": [
    "onStartupFinished",
    "onView:celest.chatPanel"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "configuration": {
      "title": "Celest",
      "properties": {
        "celest.apiBase": {
          "type": "string",
          "default": "https://api.deepseek.com",
          "description": "DeepSeek API base URL"
        },
        "celest.defaultModel": {
          "type": "string",
          "default": "deepseek-v4-flash",
          "description": "Default model for new sessions"
        },
        "celest.autoDownloadBinary": {
          "type": "boolean",
          "default": true,
          "description": "Automatically download codewhale-tui binary on first use"
        },
        "celest.binaryPath": {
          "type": "string",
          "default": "",
          "description": "Custom path to codewhale-tui binary (leave empty for auto-download)"
        },
        "celest.locale": {
          "type": "string",
          "default": "zh-CN",
          "enum": [
            "zh-CN",
            "en"
          ],
          "description": "Celest UI language (zh-CN / en)"
        },
        "celest.provider": {
          "type": "string",
          "default": "deepseek",
          "enum": [
            "deepseek", "deepseek-cn", "openai", "openai-codex",
            "anthropic", "nvidia-nim", "ollama", "huggingface",
            "arcee", "moonshot", "sglang", "vllm",
            "siliconflow", "siliconflow-CN", "fireworks",
            "xiaomi-mimo", "wanjie-ark", "volcengine",
            "openrouter", "novita", "atlascloud", "dashscope",
            "minimax"
          ],
          "description": "API provider (24 providers supported — see README for details)"
        },
        "celest.reasoningEffort": {
          "type": "string",
          "default": "max",
          "enum": [
            "off",
            "low",
            "medium",
            "high",
            "max"
          ],
          "description": "Model reasoning depth"
        },
        "celest.pathSuffix": {
          "type": "string",
          "default": "",
          "description": "Override API path suffix for OpenAI-compatible endpoints (e.g. /chat/completions). Leave empty for default."
        },
        "celest.downloadMirror": {
          "type": "string",
          "default": "auto",
          "enum": ["auto", "github", "cnb"],
          "description": "Binary download source: auto = auto-fallback, github = GitHub, cnb = CNB mirror (China-friendly)"
        },
        "celest.releaseVersion": {
          "type": "string",
          "default": "",
          "description": "Pin TUI version (empty = latest), e.g. 'v0.8.61'"
        },
        "celest.autoCompactThreshold": {
          "type": "number",
          "default": 85,
          "minimum": 0,
          "maximum": 100,
          "description": "Context usage percentage threshold for auto-compaction (0 = disabled)"
        },
        "celest.showContextBar": {
          "type": "boolean",
          "default": true,
          "description": "Show context usage progress bar in the Context panel"
        },
        "celest.allowedTools": {
          "type": "string",
          "default": "",
          "description": "Comma-separated list of allowed tools (passed to TUI --allowed-tools). Leave empty for all."
        },
        "celest.disallowedTools": {
          "type": "string",
          "default": "",
          "description": "Comma-separated list of disallowed tools (passed to TUI --disallowed-tools)"
        },
        "celest.maxTurns": {
          "type": "number",
          "default": 0,
          "minimum": 0,
          "description": "Maximum turns per session (0 = unlimited, passed to TUI --max-turns)"
        },
        "celest.hiddenSessions": {
          "type": "array",
          "default": [],
          "description": "List of hidden session IDs (deleted by user)"
        }
      }
    },
    "commands": [
      {
        "command": "celest.newSession",
        "category": "Celest",
        "title": "New Session",
        "icon": "$(add)"
      },
      {
        "command": "celest.viewHistory",
        "category": "Celest",
        "title": "View History",
        "icon": "$(history)"
      },
      {
        "command": "celest.openSettings",
        "category": "Celest",
        "title": "Open Settings",
        "icon": "$(gear)"
      },
      {
        "command": "celest.focusInput",
        "category": "Celest",
        "title": "Focus Chat Input"
      },
      {
        "command": "celest.addToChat",
        "category": "Celest",
        "title": "Add to Celest Chat",
        "icon": "$(add)"
      },
      {
        "command": "celest.deleteSession",
        "category": "Celest",
        "title": "Delete Session",
        "icon": "$(trash)"
      },
      {
        "command": "celest.clearChat",
        "category": "Celest",
        "title": "Clear Chat",
        "icon": "$(clear-all)"
      },
      {
        "command": "celest.applyCode",
        "category": "Celest",
        "title": "Apply Code from Chat"
      },
      {
        "command": "celest.acceptDiff",
        "category": "Celest",
        "title": "Accept Diff"
      },
      {
        "command": "celest.rejectDiff",
        "category": "Celest",
        "title": "Reject Diff",
        "icon": "$(stop)"
      },
      {
        "command": "celest.shareSession",
        "category": "Celest",
        "title": "Share Session as Markdown"
      },
      {
        "command": "celest.openInNewWindow",
        "category": "Celest",
        "title": "Open in New Window"
      },
      {
        "command": "celest.downloadBinary",
        "category": "Celest",
        "title": "Download TUI Binary"
      }
    ],
    "keybindings": [
      {
        "command": "celest.focusInput",
        "mac": "cmd+l",
        "key": "ctrl+l"
      },
      {
        "command": "celest.addToChat",
        "mac": "cmd+shift+l",
        "key": "ctrl+shift+l"
      },
      {
        "command": "celest.applyCode",
        "mac": "alt+a",
        "key": "alt+a"
      },
      {
        "command": "celest.acceptDiff",
        "mac": "shift+cmd+enter",
        "key": "shift+ctrl+enter",
        "when": "celest.diffVisible"
      },
      {
        "command": "celest.rejectDiff",
        "mac": "shift+cmd+backspace",
        "key": "shift+ctrl+backspace",
        "when": "celest.diffVisible"
      }
    ],
    "viewsContainers": {
      "activitybar": [
        {
          "id": "celest",
          "title": "Celest",
          "icon": "assets/icon.svg"
        }
      ]
    },
    "views": {
      "celest": [
        {
          "id": "celest.chatPanel",
          "type": "webview",
          "name": "Chat"
        },
        {
          "id": "celest.sessionsList",
          "type": "tree",
          "name": "Sessions"
        }
      ]
    },
    "menus": {
      "commandPalette": [
        {
          "command": "celest.newSession"
        },
        {
          "command": "celest.focusInput"
        },
        {
          "command": "celest.openSettings"
        }
      ],
      "editor/context": [
        {
          "command": "celest.addToChat",
          "group": "celest@1"
        }
      ],
      "explorer/context": [
        {
          "command": "celest.addToChat",
          "group": "celest@1"
        }
      ],
      "view/item/context": [
        {
          "command": "celest.deleteSession",
          "when": "viewItem == session",
          "group": "inline"
        }
      ]
    }
  },
  "scripts": {
    "build": "node build.mjs",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src --ext ts"
  },
  "devDependencies": {
    "@types/node": "^18.19.0",
    "@types/vscode": "^1.70.0",
    "@vitejs/plugin-vue": "^5.0.0",
    "@vue/test-utils": "^2.4.10",
    "esbuild": "^0.20.0",
    "jsdom": "^29.1.1",
    "typescript": "^5.5.0",
    "vite": "^5.0.0",
    "vitest": "^2.0.0",
    "vue": "^3.4.0",
    "vue-tsc": "^2.0.0"
  },
  "dependencies": {
    "highlight.js": "^11.10.0",
    "markdown-it": "^14.1.0"
  }
}
