{
  "name": "celest",
  "author": "TheEastKoi",
  "version": "0.1.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/TheEastKoi/celest"
  },
  "extensionKind": [
    "ui",
    "workspace"
  ],
  "license": "Apache-2.0",
  "displayName": "Celest",
  "description": "DeepSeek V4 powered AI coding agent for VS Code",
  "publisher": "TheEastKoi",
  "engines": {
    "vscode": "^1.70.0",
    "node": ">=18.18.0"
  },
  "categories": [
    "AI",
    "Chat",
    "Machine Learning"
  ],
  "keywords": [
    "deepseek",
    "ai",
    "agent",
    "coding",
    "celest"
  ],
  "activationEvents": [
    "onStartupFinished",
    "onView:celest.chatPanel"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "configuration": {
      "title": "Celest",
      "properties": {
        "celest.apiBase": {
          "type": "string",
          "default": "https://api.deepseek.com",
          "description": "DeepSeek API base URL"
        },
        "celest.defaultModel": {
          "type": "string",
          "default": "deepseek-v4-flash",
          "description": "Default model for new sessions"
        },
        "celest.autoDownloadBinary": {
          "type": "boolean",
          "default": true,
          "description": "Automatically download deepseek-tui binary on first use"
        },
        "celest.binaryPath": {
          "type": "string",
          "default": "",
          "description": "Custom path to deepseek-tui binary (leave empty for auto-download)"
        },
        "celest.locale": {
          "type": "string",
          "default": "zh-CN",
          "enum": ["zh-CN", "en"],
          "description": "Celest UI language (zh-CN / en)"
        },
        "celest.provider": {
          "type": "string",
          "default": "deepseek",
          "description": "API provider (deepseek, openai, nvidia-nim, ollama)"
        },
        "celest.reasoningEffort": {
          "type": "string",
          "default": "max",
          "enum": ["off", "low", "medium", "high", "max"],
          "description": "Model reasoning depth"
        }
      }
    },
    "commands": [
      {
        "command": "celest.newSession",
        "category": "Celest",
        "title": "New Session",
        "icon": "$(add)"
      },
      {
        "command": "celest.viewHistory",
        "category": "Celest",
        "title": "View History",
        "icon": "$(history)"
      },
      {
        "command": "celest.openSettings",
        "category": "Celest",
        "title": "Open Settings",
        "icon": "$(gear)"
      },
      {
        "command": "celest.focusInput",
        "category": "Celest",
        "title": "Focus Chat Input"
      },
      {
        "command": "celest.addToChat",
        "category": "Celest",
        "title": "Add to Celest Chat",
        "icon": "$(add)"
      },
      {
        "command": "celest.clearChat",
        "category": "Celest",
        "title": "Clear Chat",
        "icon": "$(clear-all)"
      },
      {
        "command": "celest.applyCode",
        "category": "Celest",
        "title": "Apply Code from Chat"
      },
      {
        "command": "celest.acceptDiff",
        "category": "Celest",
        "title": "Accept Diff"
      },
      {
        "command": "celest.rejectDiff",
        "category": "Celest",
        "title": "Reject Diff",
        "icon": "$(stop)"
      },
      {
        "command": "celest.shareSession",
        "category": "Celest",
        "title": "Share Session as Markdown"
      },
      {
        "command": "celest.openInNewWindow",
        "category": "Celest",
        "title": "Open in New Window"
      },
      {
        "command": "celest.downloadBinary",
        "category": "Celest",
        "title": "Download TUI Binary"
      }
    ],
    "keybindings": [
      {
        "command": "celest.focusInput",
        "mac": "cmd+l",
        "key": "ctrl+l"
      },
      {
        "command": "celest.addToChat",
        "mac": "cmd+shift+l",
        "key": "ctrl+shift+l"
      },
      {
        "command": "celest.applyCode",
        "mac": "alt+a",
        "key": "alt+a"
      },
      {
        "command": "celest.acceptDiff",
        "mac": "shift+cmd+enter",
        "key": "shift+ctrl+enter",
        "when": "celest.diffVisible"
      },
      {
        "command": "celest.rejectDiff",
        "mac": "shift+cmd+backspace",
        "key": "shift+ctrl+backspace",
        "when": "celest.diffVisible"
      }
    ],
    "viewsContainers": {
      "activitybar": [
        {
          "id": "celest",
          "title": "Celest",
          "icon": "assets/icon.svg"
        }
      ]
    },
    "views": {
      "celest": [
        {
          "id": "celest.chatPanel",
          "type": "webview",
          "name": "Chat"
        },
        {
          "id": "celest.sessionsList",
          "type": "tree",
          "name": "Sessions"
        }
      ]
    },
    "menus": {
      "commandPalette": [
        {
          "command": "celest.newSession"
        },
        {
          "command": "celest.focusInput"
        },
        {
          "command": "celest.openSettings"
        }
      ],
      "editor/context": [
        {
          "command": "celest.addToChat",
          "group": "celest@1"
        }
      ],
      "explorer/context": [
        {
          "command": "celest.addToChat",
          "group": "celest@1"
        }
      ]
    }
  },
  "scripts": {
    "build": "node build.mjs",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src --ext ts"
  },
  "devDependencies": {
    "@types/node": "^18.19.0",
    "@types/vscode": "^1.70.0",
    "@vitejs/plugin-vue": "^5.0.0",
    "esbuild": "^0.20.0",
    "typescript": "^5.5.0",
    "vite": "^5.0.0",
    "vitest": "^2.0.0",
    "vue": "^3.4.0",
    "vue-tsc": "^2.0.0"
  },
  "dependencies": {
    "highlight.js": "^11.10.0",
    "markdown-it": "^14.1.0"
  }
}
